generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum TransactionSignal {
  C
  D
}

enum TransactionAssignment {
  ENTRADAS
  SAIDAS
  TARIFAS
  APLICACOES
  RESGATES
  OUTROS
}

model Company {
  id        String    @id @default(cuid())
  name      String    @unique
  accounts  Account[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Account {
  id           String        @id @default(cuid())
  code         String        @unique
  bankName     String
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([companyId])
}

model Transaction {
  id          String                @id @default(cuid())
  accountId   String
  account     Account               @relation(fields: [accountId], references: [id], onDelete: Restrict)
  date        String
  description String
  amount      Decimal
  signal      TransactionSignal
  assignment  TransactionAssignment
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([accountId])
  @@index([date])
  @@index([assignment])
}