generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum TransactionSignal {
  C
  D
}

enum TransactionAssignment {
  ENTRADAS
  SAIDAS
  TARIFAS
  APLICACOES
  RENDIMENTOS
  RENDIMENTO_MENSAL
  RESGATES
  TRANSFERENCIA_EC
  OUTROS
}

enum ManualConsolidadoAssignment {
  ENTRADAS
  SAIDAS
  RESGATES
  APLICACOES
  TRANSFERENCIA_EC
}

enum ManualConsolidadoStatus {
  AUTORIZADO
  NAO_AUTORIZADO
}

enum ManualConsolidadoTransferDirection {
  ENTRADA
  SAIDA
}

model CompanyGroup {
  id        String    @id @default(cuid())
  name      String    @unique
  companies Company[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Company {
  id        String       @id @default(cuid())
  name      String       @unique
  groupId   String
  group     CompanyGroup @relation(fields: [groupId], references: [id], onDelete: Restrict)
  accounts  Account[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([groupId])
}

model Account {
  id             String                @id @default(cuid())
  code           String                @unique
  bankName       String
  companyId      String
  company        Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  transactions   Transaction[]
  manualConsolidadoEntries ManualConsolidadoEntry[]
  openingBalance AccountOpeningBalance?
  dailySummaries AccountDailySummary[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([companyId])
}

model AccountOpeningBalance {
  id                 String   @id @default(cuid())
  accountId          String   @unique
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  referenceDate      String?
  initialAvailable   Decimal  @default(0)
  initialApplication Decimal  @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AccountDailySummary {
  id             String   @id @default(cuid())
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dateKey        String
  entries        Decimal  @default(0)
  outputs        Decimal  @default(0)
  fees           Decimal  @default(0)
  yields         Decimal  @default(0)
  monthlyYields  Decimal  @default(0)
  rescues        Decimal  @default(0)
  applications   Decimal  @default(0)
  transferEcIn   Decimal  @default(0)
  transferEcOut  Decimal  @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([accountId, dateKey])
  @@index([accountId])
  @@index([dateKey])
}

model Transaction {
  id                 String                @id @default(cuid())
  accountId          String
  account            Account               @relation(fields: [accountId], references: [id], onDelete: Restrict)
  date               String
  dateKey            String
  description        String
  amount             Decimal
  signal             TransactionSignal
  assignment         TransactionAssignment
  ignoreDailySummary Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([accountId])
  @@index([date])
  @@index([dateKey])
  @@index([assignment])
}

model ManualConsolidadoEntry {
  id                String                           @id @default(cuid())
  accountId         String
  account           Account                          @relation(fields: [accountId], references: [id], onDelete: Restrict)
  date              String
  dateKey           String
  description       String
  amount            Decimal
  assignment        ManualConsolidadoAssignment
  transferDirection ManualConsolidadoTransferDirection?
  status            ManualConsolidadoStatus          @default(NAO_AUTORIZADO)
  createdAt         DateTime                         @default(now())
  updatedAt         DateTime                         @updatedAt

  @@index([accountId])
  @@index([date])
  @@index([dateKey])
  @@index([assignment])
  @@index([status])
}
